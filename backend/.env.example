# Copy to .env and fill in values. Loaded automatically when inference_server starts
# (from this directory, regardless of shell cwd).

# --- Gemini agent (required for POST /v1/agent/step) ---
GEMINI_API_KEY=

# Optional: override default household-tidying mission (single line or use \n for newlines)
# HIGH_LEVEL_INTENTION_PROMPT=You are a household robot. Your job is to clean up...
GEMINI_AGENT_MODEL=gemini-2.5-flash-lite

# Per-session Gemini I/O logs under backend/logs/*.jsonl (set 0 to skip disk I/O on each agent step)
WRITE_GEMINI_SESSION_JSONL=1

AGENT_MAX_OUTPUT_TOKENS=256
AGENT_MIN_INTERVAL_MS=500

# Short-term memory: rolling turn log size and max chars sent to the model
AGENT_MEMORY_TURNS=5
AGENT_MEMORY_MAX_CHARS=2000

# Motion anti-spam hint: user text warns if last step used motion within this many seconds
AGENT_MOTION_COOLDOWN_HINT_SEC=2

# Stored task_anchor max length after merge (model output is capped in schema separately)
AGENT_TASK_ANCHOR_MAX_LEN=128

# Server-inferred held target string from pick_up/place/drop tool sequence (chars)
AGENT_HELD_OBJECT_MAX_LEN=128

# Drop YOLO boxes below this confidence before grounding (reduces flicker)
AGENT_DETECTION_MIN_CONF=0.3

# Blinders (when task_anchor non-empty): max anchor-matching vs other detections after urgent classes
AGENT_ANCHOR_TOP_MATCH=3
AGENT_ANCHOR_TOP_REST=2

# Voice emission gate: min seconds between optional status speaks when anchor+motor unchanged
VOICE_MIN_DWELL_SEC=5

# Agent image (CPU WebP for LATEST_STATE; see plan: after GPU lock release)
AGENT_IMAGE_MAX_EDGE=512
AGENT_WEBP_QUALITY=60

# Depth: cz = rel_depth / K (calibrate once; do not use per-frame min/max)
AGENT_DEPTH_SCALE_K=1.0

# Optional: comma-separated lowercase class names to include only those detections
# AGENT_CLASS_ALLOWLIST=

AGENT_TOP_N_DETECTIONS=20

# Max rows kept when merging detector outputs across frames since the last successful agent step (then anchor prioritization may trim further)
AGENT_ACCUM_GROUNDED_MAX=96

AGENT_SECTOR_LEFT_MAX=0.33
AGENT_SECTOR_RIGHT_MIN=0.66
AGENT_SECTOR_UPPER_MAX=0.33
AGENT_SECTOR_LOWER_MIN=0.66

# --- Inference server ---
INFERENCE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# YOLO weights (defaults shown; uncomment to override)
# YOLO_MODEL_OIV7=yolov8n-oiv7.pt
# YOLO_MODEL_COCO=yolov8n.pt
# YOLO_MODEL=

# MiDaS: reuse depth map every N frames (1 = every frame)
MIDAS_EVERY_N=1

# JPEG depth preview (Inferno false-color) in WebSocket JSON and GET /v1/depth_preview (MiDaS tab). Set 0 to save bandwidth.
INCLUDE_DEPTH_PREVIEW=1

# Every /ws/infer frame: log YOLO count sent on the WebSocket vs grounded count after AGENT_* filters (for debugging UI parity).
# WS_INFER_LOG_DET_COUNT=1
